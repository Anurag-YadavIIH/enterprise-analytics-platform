# ------------------------------------------------------------------
# Enterprise Analytics Platform — environment configuration
# Copy to .env and adjust. NEVER commit the real .env.
# ------------------------------------------------------------------

# Runtime environment: local | docker | ci | prod
EAP_ENV=local

# --- Paths (relative to repo root unless absolute) ---
EAP_DATA_RAW=data/raw
EAP_DATA_PROCESSED=data/processed
EAP_DATA_PARQUET=data/parquet
EAP_DATA_WAREHOUSE=data/warehouse

# --- PostgreSQL (analytics warehouse) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=olist
POSTGRES_USER=analytics
POSTGRES_PASSWORD=analytics
# Full SQLAlchemy URL (auto-built if left blank)
EAP_WAREHOUSE_URL=

# --- DuckDB (local OLAP engine used by dbt + Streamlit) ---
EAP_DUCKDB_PATH=data/warehouse/olist.duckdb

# --- Kaggle dataset ---
KAGGLE_DATASET=olistbr/brazilian-ecommerce
# Optional: if unset, ingestion falls back to a local zip in data/raw
KAGGLE_USERNAME=
KAGGLE_KEY=

# --- Spark ---
SPARK_MASTER=local[*]
SPARK_APP_NAME=eap-spark
SPARK_SHUFFLE_PARTITIONS=8

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_TITLE=Olist Analytics API
API_LOG_LEVEL=info

# --- Streamlit ---
STREAMLIT_SERVER_PORT=8501

# --- MLflow ---
MLFLOW_TRACKING_URI=http://localhost:5000

# --- Logging ---
EAP_LOG_LEVEL=INFO
EAP_LOG_JSON=false
